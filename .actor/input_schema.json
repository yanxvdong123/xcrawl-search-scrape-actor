{
  "schemaVersion": 1,
  "title": "Input Configuration",
  "type": "object",
  "required": ["action"],
  "properties": {
    "action": { "type": "string", "title": "Action", "enum": ["search","scrape"], "default": "search", "description": "Action to perform: search or scrape", "editor": "select" },
    "query": { "type": "string", "title": "Search Query", "maxLength": 200, "description": "Search query (required for action=search)", "editor": "textfield" },
    "url": { "type": "string", "title": "URL", "maxLength": 2000, "description": "URL to scrape (required for action=scrape)", "editor": "textfield" },
    "location": { "type": "string", "title": "Location", "default": "US", "description": "Search location (e.g. US, UK, CN, JP)", "editor": "textfield" },
    "language": { "type": "string", "title": "Language", "default": "en", "description": "Search language (e.g. en, zh, ja)", "editor": "textfield" },
    "limit": { "type": "integer", "title": "Result Limit", "default": 5, "maximum": 20, "description": "Number of search results (1-20)", "editor": "number" }
  }
}